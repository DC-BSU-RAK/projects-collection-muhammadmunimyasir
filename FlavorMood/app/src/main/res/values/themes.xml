<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme -->
    <style name="Theme.FlavorMood" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primaryDark</item>
        <item name="colorPrimaryVariant">@color/primaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:windowBackground">@color/background</item>
        <!-- Hide the action bar on all screens -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Splash screen theme — full screen, no action bar -->
    <style name="Theme.FlavorMood.Splash" parent="Theme.FlavorMood">
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
