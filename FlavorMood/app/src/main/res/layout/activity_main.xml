<?xml version="1.0" encoding="utf-8"?>
<!-- Main Calculator Screen Layout -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Row: Title + Info Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🍽️ Flavor Mood"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/primaryDark"
                android:fontFamily="sans-serif-condensed" />

            <!-- Info button opens the modal dialog -->
            <Button
                android:id="@+id/btn_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ⓘ How It Works"
                android:textSize="12sp"
                android:backgroundTint="@color/primaryLight"
                android:textColor="@color/primaryDark" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Discover what food matches your mood today"
            android:textSize="14sp"
            android:textColor="@color/textSecondary"
            android:layout_marginBottom="28dp" />

        <!-- ===== STEP 1: Pick Your Mood ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 — How are you feeling?"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/primaryDark"
            android:layout_marginBottom="12dp" />

        <!-- Mood buttons in a 2x2 grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:layout_marginBottom="28dp">

            <Button
                android:id="@+id/btn_happy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="😄 Happy"
                android:backgroundResource="@drawable/btn_unselected"
                android:textColor="@color/primaryDark" />

            <Button
                android:id="@+id/btn_tired"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="😴 Tired"
                android:backgroundResource="@drawable/btn_unselected"
                android:textColor="@color/primaryDark" />

            <Button
                android:id="@+id/btn_stressed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="😤 Stressed"
                android:backgroundResource="@drawable/btn_unselected"
                android:textColor="@color/primaryDark" />

            <Button
                android:id="@+id/btn_adventurous"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="🤩 Adventurous"
                android:backgroundResource="@drawable/btn_unselected"
                android:textColor="@color/primaryDark" />

        </GridLayout>

        <!-- ===== STEP 2: Pick Time of Day ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 2 — What time is it?"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/primaryDark"
            android:layout_marginBottom="12dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:layout_marginBottom="28dp">

            <Button
                android:id="@+id/btn_morning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="🌅 Morning"
                android:backgroundResource="@drawable/btn_unselected"
                android:textColor="@color/primaryDark" />

            <Button
                android:id="@+id/btn_afternoon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="☀️ Afternoon"
                android:backgroundResource="@drawable/btn_unselected"
                android:textColor="@color/primaryDark" />

            <Button
                android:id="@+id/btn_evening"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="🌆 Evening"
                android:backgroundResource="@drawable/btn_unselected"
                android:textColor="@color/primaryDark" />

            <Button
                android:id="@+id/btn_late_night"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="🌙 Late Night"
                android:backgroundResource="@drawable/btn_unselected"
                android:textColor="@color/primaryDark" />

        </GridLayout>

        <!-- ===== CALCULATE Button ===== -->
        <Button
            android:id="@+id/btn_calculate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="✨ Find My Flavor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primaryDark"
            android:textColor="@color/white"
            android:layout_marginBottom="24dp" />

        <!-- ===== RESULT Card (hidden until calculated) ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/primaryLight"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- Emoji for the food -->
                <TextView
                    android:id="@+id/tv_result_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍽️"
                    android:textSize="64sp"
                    android:layout_marginBottom="8dp" />

                <!-- Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR FLAVOR TODAY IS"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textColor="@color/textSecondary" />

                <!-- Food Name -->
                <TextView
                    android:id="@+id/tv_result"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Açaí Bowl"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="@color/primaryDark"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp" />

                <!-- Description -->
                <TextView
                    android:id="@+id/tv_result_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="@color/textSecondary"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
